# ─── QuantOS Local Agent Configuration ───────────────────────────────────────
# Copy to agent/config.yaml and fill in your values.
# This file stays on YOUR machine — never synced to QuantOS servers.

broker: fyers              # fyers | zerodha | angel_one | upstox

credentials:
  api_key: YOUR_API_KEY
  api_secret: YOUR_API_SECRET
  redirect_uri: YOUR_REDIRECT_URI   # Fyers only

risk:
  capital: 500000                   # Reference only — actual sizing uses live broker.get_funds()
  max_risk_per_trade: 0.02          # 2% max risk per trade
  max_open_positions: 5             # Maximum concurrent positions
  max_daily_loss: 0.05              # 5% daily loss circuit breaker
  product_type: INTRADAY            # INTRADAY | CNC | MARGIN — used for both the entry and the SL_M stop order
  assumed_stop_pct: 0.015           # Fallback stop-loss % used only if a signal has no stop_loss
  auto_exit: true                   # After the entry fills, place a second SL_M stop order at the
                                     # Darvas stop_loss level, trailed up automatically as new boxes
                                     # form. Set false to disable (e.g. for delivery trades you intend
                                     # to manage manually).

cloud:
  api_url: https://your-quantos-instance.railway.app
  api_secret: YOUR_CLOUD_API_SECRET # Must match CLOUD_API_SECRET in cloud Railway variables
  webhook_secret: YOUR_WEBHOOK_SECRET # Must match WEBHOOK_SECRET in cloud Railway variables —
                                       # used when the internal scanner (below) POSTs a
                                       # synthetic alert to /webhook/tradingview, same as
                                       # TradingView's own Pine Script alerts do.

# Note: Telegram confirm/skip (ADR-05) is handled entirely on the cloud side
# (cloud/api/main.py /webhook/telegram) — this agent only polls /signals for
# CONFIRMED status via REST, it never talks to Telegram directly.

claude:
  tier: pro                         # free | pro | enterprise
  min_confluence_score: 70          # Only call Claude above this threshold
  regime_cache_ttl: 900             # Seconds — 15 min cache on regime calls

scanner:
  enabled: true                     # Two-stage Darvas discovery + timing pipeline:
                                     #   Stage A (core/darvas/weekly_discovery.py) — once/day,
                                     #     scans universe_file on daily/weekly bars for candidates.
                                     #   Stage B (core/darvas/scanner.py) — every
                                     #     granular_scan_interval_minutes during market hours,
                                     #     times the intraday entry on Stage A's shortlist and
                                     #     POSTs any fired signal to /webhook/tradingview.
  universe_file: agent/universe.txt # Symbols Stage A scans daily — edit freely.
  granular_scan_interval_minutes: 5 # How often Stage B re-scans the candidate shortlist.
