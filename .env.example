# ─── QuantOS Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Fyers (v1 broker) ────────────────────────────────────────────────────────
FYERS_APP_ID=
FYERS_SECRET_KEY=
FYERS_REDIRECT_URI=

# ── Zerodha / Kite (v1 broker) ───────────────────────────────────────────────
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# ── CallMeBot / WhatsApp notifications ───────────────────────────────────────
CALLMEBOT_PHONE=
CALLMEBOT_API_KEY=

# ── Database (Postgres) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/quantos

# ── Cloud API ────────────────────────────────────────────────────────────────
CLOUD_API_SECRET=          # Shared secret between local agent and cloud API
WEBHOOK_SECRET=            # TradingView webhook validation secret

# ── App config ───────────────────────────────────────────────────────────────
ENVIRONMENT=development    # development | production
LOG_LEVEL=INFO
